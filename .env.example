NODE_ENV=development
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gestor-frota-pr

# JWT
JWT_SECRET=gestor-frota-pr-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# SMTP (E-mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@gestorfrota.com.br

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Admin alerts recipient
ADMIN_EMAIL=admin@gestorfrota.com.br
ADMIN_PHONE=41999990000

# Frontend
FRONTEND_URL=http://localhost:3000

# ─── Detran PR - Frotista API ──────────────────────────────────────────────
# URL de autenticação OAuth2
DETRAN_AUTH_URL=https://auth-cs.identidadedigital.pr.gov.br/centralautenticacao/api/v1/token/jwt
# URL base da API Gateway
DETRAN_API_URL=https://apigateway.paas.pr.gov.br/detran/frotista/api/v1
# Credenciais (Client_Id e Client_Secret) fornecidas pelo Detran/PR após credenciamento
DETRAN_CLIENT_ID=
DETRAN_CLIENT_SECRET=
